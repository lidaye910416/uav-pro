# =============================================================================
# UAV-PRO .gitignore
# 无人机低空检测智能安全预警系统
# =============================================================================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
*.egg
MANIFEST

# Pytest
.pytest_cache/
.coverage
htmlcov/
*.cover

# Virtual environments
venv/
ENV/
env/
.venv/

# =============================================================================
# Node.js
# =============================================================================
node_modules/
*/node_modules/
.npm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Large Model Files (YOLO, SAM, etc.)
# =============================================================================
*.pt
*.pth
*.onnx
*.pkl
*.h5
*.pkl
models/*.pt
models/*.pth

# =============================================================================
# Media Files (Videos, Images, Audio)
# =============================================================================
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv
*.Mp4
*.webm
*.m4v

*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.svg
*.ico
*.webp

*.wav
*.mp3
*.flac
*.ogg
*.m4a

data/streams/*
!data/streams/.gitkeep
data/frames/*
!data/frames/.gitkeep
data/knowledge_base/*
!data/knowledge_base/.gitkeep

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
credentials.json
secrets.json

# =============================================================================
# Build & Distribution
# =============================================================================
.next/
out/
.next/
.turbo/
dist/
build/

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
*.sublime-project

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
*.log.*
access.log
error.log

# =============================================================================
# System Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Testing & Coverage
# =============================================================================
tests/test_output/
tests/fixtures/
coverage/
.nyc_output/

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.orig

# =============================================================================
# Backend specific
# =============================================================================
backend.log
*.db
*.sqlite
*.sqlite3
chromadb/

# =============================================================================
# Claude Code (local settings)
# =============================================================================
.claude/settings.local.json
.claude/*.log

# =============================================================================
# Keep these empty directories
# =============================================================================
data/streams/.gitkeep
data/frames/.gitkeep
data/knowledge_base/.gitkeep
