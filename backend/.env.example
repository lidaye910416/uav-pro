# UAV低空检测系统 - 环境变量示例
# 复制为 .env 并修改

# 数据库 (开发用 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./uav.db

# 生产环境推荐 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://uav_user:your_password@localhost:5432/uav_db

# JWT密钥 (必须修改为强随机密钥)
SECRET_KEY=your-super-secret-key-change-in-production

# API版本
VERSION=1.0.0
