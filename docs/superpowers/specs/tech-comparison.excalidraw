    {
      "id": "gap-title",
      "type": "text",
      "x": 70,
      "y": 495,
      "width": 200,
      "height": 30,
      "text": "🔴 关键差距分析",
      "fontSize": 18,
      "fontWeight": "bold"
    },
    {
      "id": "gap1",
      "type": "text",
      "x": 70,
      "y": 540,
      "width": 400,
      "height": 25,
      "text": "1. 缺少运动检测前置过滤 → 大量背景误检",
      "fontSize": 14
    },
    {
      "id": "gap2",
      "type": "text",
      "x": 70,
      "y": 570,
      "width": 400,
      "height": 25,
      "text": "2. 缺少多模态融合 → 纯视觉容易误判",
      "fontSize": 14
    },
    {
      "id": "gap3",
      "type": "text",
      "x": 70,
      "y": 600,
      "width": 400,
      "height": 25,
      "text": "3. 缺少时序分析 → 单帧无法判断运动状态",
      "fontSize": 14
    },
    {
      "id": "gap4",
      "type": "text",
      "x": 70,
      "y": 630,
      "width": 400,
      "height": 25,
      "text": "4. 缺少Register机制 → 无法识别已知UAV",
      "fontSize": 14
    }
  ],
