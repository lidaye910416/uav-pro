# UAV-PRO 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# ==================== 服务端口配置 ====================
# 后端服务
BACKEND_PORT=8888
BACKEND_HOST=127.0.0.1

# Ollama AI 服务
OLLAMA_PORT=11434

# 前端应用
SHOWCASE_PORT=4000
DASHBOARD_PORT=4001
ADMIN_PORT=4002

# ==================== API 地址配置 ====================
# 后端 API 地址 (前端使用)
NEXT_PUBLIC_API_BASE=http://localhost:8888

# ==================== 其他配置 ====================
NODE_ENV=development
