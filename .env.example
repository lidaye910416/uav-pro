# UAV-PRO 环境变量配置
# 复制此文件为 .env 并根据实际情况修改
# 注意：端口配置统一由 ecosystem.config.js 读取并传递给各服务

# ==================== 服务端口配置 ====================
# 后端服务
BACKEND_PORT=8888
BACKEND_HOST=127.0.0.1

# Ollama AI 服务
OLLAMA_PORT=11434

# 前端应用端口（必须与 package.json 中的 ${PORT:-默认值} 一致）
SHOWCASE_PORT=3000
DASHBOARD_PORT=3001
ADMIN_PORT=3002

# ==================== 其他配置 ====================
NODE_ENV=development
